# --- Convex ---
# Set automatically by `npx convex dev`. Do not commit real values.
NEXT_PUBLIC_CONVEX_URL=

# --- Meta / Instagram app ---
# From your Meta app dashboard (App Settings -> Basic). Used to verify webhook signatures (HMAC SHA-256).
META_APP_SECRET=
# Whatever string you choose; you'll paste the same string into Meta's webhook subscription page.
META_WEBHOOK_VERIFY_TOKEN=change-me-to-something-random
